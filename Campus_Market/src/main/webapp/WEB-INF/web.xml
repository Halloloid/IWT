<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>Campus Market</display-name>

    <welcome-file-list>
        <welcome-file>signin.html</welcome-file>
        <welcome-file>home.html</welcome-file>
    </welcome-file-list>

    <!-- RegisterServlet: handles sign-up form from signin.html -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.market.servlets.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>

    <!-- LoginServlet: handles login form from signin.html -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.market.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- PostItemServlet: handles post-item.html form submission + file upload -->
    <servlet>
        <servlet-name>PostItemServlet</servlet-name>
        <servlet-class>com.market.servlets.PostItemServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PostItemServlet</servlet-name>
        <url-pattern>/PostItemServlet</url-pattern>
    </servlet-mapping>

    <!-- BrowseServlet: returns items as JSON for home.html and item-details.html -->
    <servlet>
        <servlet-name>BrowseServlet</servlet-name>
        <servlet-class>com.market.servlets.BrowseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BrowseServlet</servlet-name>
        <url-pattern>/BrowseServlet</url-pattern>
    </servlet-mapping>

    <!-- ItemDetailServlet: returns single item as JSON for item-details.html -->
    <servlet>
        <servlet-name>ItemDetailServlet</servlet-name>
        <servlet-class>com.market.servlets.ItemDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ItemDetailServlet</servlet-name>
        <url-pattern>/ItemDetailServlet</url-pattern>
    </servlet-mapping>

    <!-- ProfileServlet: returns logged-in user's profile + listings as JSON -->
    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.market.servlets.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/ProfileServlet</url-pattern>
    </servlet-mapping>

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
